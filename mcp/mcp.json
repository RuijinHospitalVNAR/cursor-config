{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "Persistent memory across sessions"
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{{USER_HOME}}"],
      "description": "Filesystem operations - user home (global)"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "description": "Live documentation lookup"
    },
    "firecrawl-mcp": {
      "command": "firecrawl-mcp",
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY_HERE"
      }
    },
    "github": {
      "command": "{{PYTHON_PATH}}",
      "args": ["-m", "mcp_server_git", "--repository", "{{GIT_REPO_PATH}}"]
    },
    "Sequential Thinking": {
      "url": "https://mcpmarket.cn/mcp/a60aecaa274067fde033a169",
      "headers": {}
    },
    "MarkItDown MCP": {
