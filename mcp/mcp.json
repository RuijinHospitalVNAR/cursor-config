      "headers": {}
    },
    "Jina": {
      "url": "https://mcpmarket.cn/mcp/b98dabe4cfef03f4cde4a773",
      "headers": {}
    },
    "@magicuidesign/mcp": {
      "command": "npx",
      "args": ["-y", "@magicuidesign/mcp@latest"]
    },
    "arXiv论文": {
      "url": "https://mcpmarket.cn/mcp/31fac35d1841c9d7ac0c6026",
      "headers": {}
    },
    "Office Word": {
      "url": "https://mcpmarket.cn/mcp/1343d6c8808dbe93371ebb86",
      "headers": {}
    },
    "git": {
      "command": "{{PYTHON_PATH}}",
      "args": ["-m", "mcp_server_git", "--repository", "{{GIT_REPO_PATH}}"]
    },
    "data_visualization": {
